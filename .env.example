# shared runner repo-local automation runtime
# Copy this file to `.env` and fill only the stages you want to open.
# Leaving a section commented out keeps that stage gated.

# -----------------------------------------------------------------------------
# GitNexus
# Use the Docker wrapper when GitNexus should run inside a container.
# Build the image from /home/shimizu/project/automation-gitnexus first:
# docker build -f gitnexus/Dockerfile.runtime -t automation-gitnexus:local .
# -----------------------------------------------------------------------------
# AUTOMATION_GITNEXUS_BIN=/home/shimizu/project/automation-hub/scripts/automation/gitnexus/docker-gitnexus.sh
# AUTOMATION_GITNEXUS_DOCKER_IMAGE=automation-gitnexus:local
# AUTOMATION_GITNEXUS_DOCKER_MOUNT_ROOT=/home/shimizu/project

# -----------------------------------------------------------------------------
# GitHub sync
# Needed for issue label sync, issue writeback, remote PR, and some deploy flows.
# Quick token steps: see docs/GITHUB_TOKEN_SETUP.md
# -----------------------------------------------------------------------------
GITHUB_TOKEN=ghp_replace_me

# -----------------------------------------------------------------------------
# Code writing
# Code writing is intentionally opt-in. You must choose the exact writer command
# that Miyabi is allowed to run.
# -----------------------------------------------------------------------------
AUTOMATION_ENABLE_CODEGEN_WRITE=true
AUTOMATION_CODEGEN_COMMAND="npm run agent:codegen"

# Optional stronger write contract
# AUTOMATION_CODEGEN_ALLOWED_PATHS=scripts/automation docs
# AUTOMATION_CODEGEN_REQUIRE_CHANGES=true
# AUTOMATION_CODEGEN_POSTCHECK_COMMAND=npm run typecheck

# -----------------------------------------------------------------------------
# Remote PR
# Requires GITHUB_TOKEN.
# -----------------------------------------------------------------------------
# AUTOMATION_ENABLE_PR_WRITE=true
# AUTOMATION_PR_REVIEWERS=octocat
# AUTOMATION_PR_LABELS=agent:pr ready-for-review
# AUTOMATION_PR_REQUIRE_MERGEABLE=true

# -----------------------------------------------------------------------------
# Deploy
# Choose either an explicit command or a provider preset.
# Requires GITHUB_TOKEN for GitHub-backed deploy flows.
# -----------------------------------------------------------------------------
# AUTOMATION_ENABLE_DEPLOY=true
# AUTOMATION_DEPLOY_COMMAND=your-deploy-command-here

# Provider preset example
# AUTOMATION_ENABLE_DEPLOY=true
# AUTOMATION_DEPLOY_USE_PROVIDER_PRESET=true
# AUTOMATION_DEPLOY_PROVIDER=cloud-run
# AUTOMATION_DEPLOY_TARGET=backend
